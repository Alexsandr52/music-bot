# ==================================
# Telegram Music Bot - Конфигурация
# ==================================
# Скопируйте этот файл в .env и заполните своими данными

# Telegram Bot API Token
# Получите у @BotFather в Telegram
# 1. Откройте @BotFather
# 2. Отправьте /newbot
# 3. Следуйте инструкциям
# 4. Скопируйте токен ниже
BOT_TOKEN=your_bot_token_here

# Прокси для yt-dlp (ОБЯЗАТЕЛЬНО для регионов без доступа к YouTube)
# Форматы:
#   HTTP: "http://user:password@host:port"
#   SOCKS5: "socks5://user:password@host:port"
#
# Бесплатные варианты:
# - Cloudflare WARP (см. README)
# - TOR (медленно)
#
# Платные прокси (рекомендуются):
# - proxy6.net
# - astraproxy.com
PROXY=

# ==================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# ==================================

# Количество результатов поиска (по умолчанию: 5)
# SEARCH_LIMIT=5

# Максимальное количество хранимых треков (по умолчанию: 50)
# MAX_TRACKS=50

# Папка для сохранения треков (по умолчанию: tracks)
# TRACKS_DIR=tracks
